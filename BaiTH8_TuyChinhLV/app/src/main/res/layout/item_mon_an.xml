<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <LinearLayout
        android:layout_marginBottom="2dp"
        android:background="#F6E694"
        android:layout_width="match_parent"
        android:layout_height="99dp">

        <ImageView
            android:id="@+id/ivAnhDaiDien"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="10dp"
            android:layout_gravity="center">
        </ImageView>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="322dp"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/tvTenMonAn"
                android:text="Cơm tấm sườn"
                android:textColor="#165D53"
                android:textStyle="bold"
                android:textSize="18dp"
                android:gravity="center|left"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            </TextView>
            <TextView
                android:id="@+id/tvDonGia"
                android:textColor="#E91414"
                android:textStyle="bold"
                android:textSize="16dp"

                android:text="25,000d"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            </TextView>

            <TextView
                android:id="@+id/tvMoTa"
                android:text="Cơm tấm sườn siêu ngon có cơm và miếng sườn "
                android:textColor="@color/black"
                android:textSize="13dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </TextView>
        </LinearLayout>

    </LinearLayout> <!-- Mon 1 -->






</LinearLayout>